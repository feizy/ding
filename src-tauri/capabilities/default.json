{
  "$schema": "https://raw.githubusercontent.com/nicegoodthings/nicegoodthings/main/schema.json",
  "identifier": "default",
  "description": "Default capabilities for ding",
  "windows": ["widget"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-start-dragging",
    "shell:allow-open"
  ]
}
